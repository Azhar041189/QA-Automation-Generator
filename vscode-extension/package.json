{
    "name": "qa-test-generator",
    "displayName": "QA Test Generator",
    "description": "Generate automation tests from manual test cases",
    "version": "0.0.1",
    "publisher": "qa-extension",
    "engines": {
        "vscode": "^1.60.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onCommand:qa.generateTest"
    ],
    "main": "./extension.js",
    "contributes": {
        "commands": [
            {
                "command": "qa.generateTest",
                "title": "Generate Automation Test"
            }
        ]
    },
    "scripts": {
        "lint": "eslint .",
        "pretest": "npm run lint",
        "test": "node ./test/runTest.js"
    },
    "devDependencies": {
        "@types/vscode": "^1.60.0",
        "@types/glob": "^7.2.0",
        "@types/mocha": "^9.0.0",
        "@types/node": "14.x",
        "eslint": "^7.27.0",
        "glob": "^7.1.7",
        "mocha": "^9.0.0",
        "typescript": "^4.3.2",
        "vscode-test": "^1.5.0"
    }
}